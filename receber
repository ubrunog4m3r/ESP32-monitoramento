void aoReceber(const esp_now_recv_info *info, const uint8_t* data, int len){
  memcpy(&dados, data, sizeof(dados));

  Serial.print("Temperatura: ");    
  Serial.println(dados.temperatura);
  Serial.print("Umidade: "); 
  Serial.println(dados.umidade);
  Serial.print("Distancia: ");     
  Serial.println(dados.distancia);
}

void setupEspNow(){
  WiFi.mode(WIFI_STA);
  if(esp_now_init() != ESP_OK){
    Serial.println("Erro ao iniciar ESP-NOW");
    delay(2000);
    ESP.restart();
  }

  esp_now_register_recv_cb(aoReceber);
  Serial.println("Receptor pronto");
}
